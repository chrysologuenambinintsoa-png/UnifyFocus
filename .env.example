# SQLite database connection
DATABASE_URL=file:./db/app.db

# ========================================
# AI PROVIDER CONFIGURATION
# ========================================
# Choose: SILICONFLOW, HUGGINGFACE, AUTO, GROQ, GITHUB_MODEL, GEMINI, AIMUSIC, MISTRAL_AI, CLOUDFLARE_WORKERS_AI, or ELEVENLABS
# AUTO will select the first configured provider able to handle the requested action
# (text, code, image, video, audio) and fall back to the next available provider.
# Routing hints: text => GROQ, image => SILICONFLOW, video => SILICONFLOW, audio => AIMUSIC
AI_PROVIDER=AUTO

# ========================================
# SILICONFLOW - Image & Video Generation
# ========================================
# Capabilities: Text (chat/code), Image generation, Image editing, Video generation, Video editing
# Best for: High-quality image and video generation with multiple model options
# Documentation: https://platform.siliconflow.cn
SILICONFLOW_API_KEY="your-siliconflow-api-key"
SILICONFLOW_API_BASE="https://api.siliconflow.com/v1"
# Text/Code generation models
SILICONFLOW_MODEL="your-chat-model-id"
SILICONFLOW_MODEL_ALT_1="your-chat-model-alt-1"
SILICONFLOW_MODEL_ALT_2="your-chat-model-alt-2"
SILICONFLOW_MODEL_ALT_3="your-chat-model-alt-3"
SILICONFLOW_MODEL_ALT_4="your-chat-model-alt-4"
SILICONFLOW_MODEL_ALT_5="your-chat-model-alt-5"
# Image generation models
SILICONFLOW_IMAGE_MODEL="your-image-model-id"
SILICONFLOW_IMAGE_MODEL_ALT_1="your-image-model-alt-1"
SILICONFLOW_IMAGE_MODEL_ALT_2="your-image-model-alt-2"
SILICONFLOW_IMAGE_MODEL_ALT_3="your-image-model-alt-3"
SILICONFLOW_IMAGE_MODEL_ALT_4="your-image-model-alt-4"
SILICONFLOW_IMAGE_MODEL_ALT_5="your-image-model-alt-5"
# Image editing/manipulation models
SILICONFLOW_IMAGE_EDIT_MODEL="your-image-edit-model-id"
SILICONFLOW_IMAGE_EDIT_MODEL_ALT_1="your-image-edit-model-alt-1"
SILICONFLOW_IMAGE_EDIT_MODEL_ALT_2="your-image-edit-model-alt-2"
# Video generation models
SILICONFLOW_VIDEO_MODEL="your-video-model-id"
SILICONFLOW_VIDEO_MODEL_ALT_1="your-video-model-alt-1"
# Video editing models
SILICONFLOW_VIDEO_EDIT_MODEL="your-video-edit-model-id"

# ========================================
# GROQ - Fast Text/Code Generation
# ========================================
# Capabilities: Text generation, Code generation
# Best for: Fast inference on text-based tasks with low latency
# Documentation: https://groq.com
GROQ_API_KEY="your-groq-api-key"
GROQ_API_BASE="https://api.groq.com/openai/v1"
GROQ_IMAGE_API_BASE="https://api.groq.com/v1"
GROQ_MODEL="mixtral-8x7b-32768"

# ========================================
# GITHUB MODEL - Enterprise Code & Text
# ========================================
# Capabilities: Text generation, Code generation, Code analysis
# Best for: GitHub-native enterprise deployments and code-focused tasks
# Documentation: https://github.com/models
GITHUB_MODEL_API_KEY="your-github-model-api-key"
GITHUB_MODEL_API_BASE="https://models.inference.ai.azure.com"
GITHUB_MODEL_MODEL="gpt-4o"

# ========================================
# GEMINI - Multi-modal Generation (Google)
# ========================================
# Capabilities: Text generation, Code generation, Image analysis, Image generation, Video generation
# Best for: Multi-modal tasks requiring vision and video understanding
# Documentation: https://ai.google.dev
GEMINI_API_KEY=""
GEMINI_API_BASE="https://api.ai.google.com"
GEMINI_MODEL="gemini-1.5-pro"
GEMINI_VIDEO_MODEL="veo-2.0-generate-001"

# ========================================
# AI MUSIC API - Audio + Text
# ========================================
# Capabilities: Text generation, Audio generation
# Best for: Music creation from prompts and audio transformations
# Documentation: https://api.ai-music.com
AIMUSIC_API_KEY=""
AIMUSIC_API_BASE="https://api.ai-music.com/v1"
AIMUSIC_MODEL="audiomix-1"

# ========================================
# MISTRAL AI - Advanced Language Models
# ========================================
# Capabilities: Text generation, Code generation, Reasoning tasks
# Best for: Enterprise-grade language understanding and complex reasoning
# Documentation: https://docs.mistral.ai
MISTRAL_AI_API_KEY="your-mistral-ai-api-key"
MISTRAL_AI_API_BASE="https://api.mistral.ai/v1"
MISTRAL_AI_MODEL="mistral-large-latest"

# ========================================
# CLOUDFLARE WORKERS AI - Edge Deployment
# ========================================
# Capabilities: Text generation, Image generation, Text-to-speech
# Best for: Edge computing with low latency and distributed inference
# Documentation: https://developers.cloudflare.com/workers-ai
CLOUDFLARE_WORKERS_AI_API_KEY="your-cloudflare-workers-ai-api-key"
CLOUDFLARE_WORKERS_AI_ACCOUNT_ID="your-account-id"
CLOUDFLARE_WORKERS_AI_MODEL="@cf/meta/llama-2-7b-chat-int8"

# ========================================
# HUGGINGFACE - Multi-purpose Generation
# ========================================
# Capabilities: Text generation, Image generation, Video generation
# Best for: Open-source models and flexible model selection
# Documentation: https://huggingface.co/inference-api
HF_API_KEY="your-hugging-face-api-key"
HF_API_BASE="https://api-inference.huggingface.co"
HF_TEXT_MODEL="mistralai/Mistral-7B-Instruct-v0.1"
HF_IMAGE_MODEL="stabilityai/stable-diffusion-2"
HF_VIDEO_MODEL="damo-vilab/text-to-video-ms-1.7b"

# ========================================



# ========================================
# APPLICATION & SERVICE CONFIGURATION
# ========================================

# ========================================
# APPLICATION & SERVICE CONFIGURATION
# ========================================
# Application URL (for OAuth redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ========================================
# PAYMENT PROCESSING - Stripe
# ========================================
# Configuration for handling subscriptions and payments
# Plans: Pro (monthly), Enterprise (custom pricing)
# Documentation: https://stripe.com/docs
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_PRO="price_1ExamplePro"
STRIPE_PRICE_ENTERPRISE="price_1ExampleEnterprise"

# ========================================
# OAUTH AUTHENTICATION
# ========================================
# Multi-provider authentication for user login
# Documentation: https://next-auth.js.org

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-google-client-id"

# GitHub OAuth
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"
NEXT_PUBLIC_GITHUB_CLIENT_ID="your-github-client-id"

# Facebook OAuth
FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-app-secret"
NEXT_PUBLIC_FACEBOOK_APP_ID="your-facebook-app-id"

# ========================================
# EMAIL & NOTIFICATIONS
# ========================================
# Configuration for sending emails and managing support requests
SUPPORT_EMAIL="support@example.com"
SUPPORT_NAME="UnifyFocus Support"
ADMIN_EMAIL="admin@example.com"

# SMTP Configuration for outgoing emails
# Leave empty to disable email sending (messages logged to console/file)
SMTP_HOST="smtp.mailprovider.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="smtp-user"
SMTP_PASS="smtp-password"
