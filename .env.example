# SQLite database connection
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:./db/app.db

# ========================================
# AI PROVIDER CONFIGURATION
# ========================================
# deAPI is the default provider for text, image, video and audio generation.
# To use deAPI.ai, configure the DEAPI variables below.
AI_PROVIDER=DEAPI

# deAPI.ai - Music, image and video generation
# Capabilities: Audio generation, music, image and video generation
# Documentation: https://deapi.ai
# DEAPI_API_KEY="your-deapi-api-key"
# DEAPI_API_BASE="https://api.deapi.ai"
# DEAPI_MODEL="audiomix-1"
# Optional deAPI.ai model overrides for image/video generation
# DEAPI_IMAGE_MODEL="your-image-model-id"
# DEAPI_IMAGE_EDIT_MODEL="your-image-edit-model-id"
# DEAPI_VIDEO_MODEL="your-video-model-id"
# DEAPI_VIDEO_EDIT_MODEL="your-video-model-id"
# Groq AI provider configuration
# Capabilities: chat, text, code
# AI_PROVIDER=GROQ
# GROQ_API_KEY="your-groq-api-key"
# GROQ_API_BASE="https://api.groq.com/v1"
# GROQ_MODEL="gpt-4o"
# Optional web search configuration
# SEARCH_API_KEY="your-search-api-key"
# SEARCH_ENGINE_ID="your-search-engine-id"

# ========================================


# ========================================
# APPLICATION & SERVICE CONFIGURATION
# ========================================
# Application URL (for OAuth redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# ========================================
# PAYMENT PROCESSING - Stripe
# ========================================
# Configuration for handling subscriptions and payments
# Plans: Pro (monthly), Enterprise (custom pricing)
# Documentation: https://stripe.com/docs
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_PRO="price_1ExamplePro"
STRIPE_PRICE_ENTERPRISE="price_1ExampleEnterprise"

# ========================================
# OAUTH AUTHENTICATION
# ========================================
# Multi-provider authentication for user login
# Documentation: https://next-auth.js.org

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-google-client-id"

# GitHub OAuth
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"
NEXT_PUBLIC_GITHUB_CLIENT_ID="your-github-client-id"

# Facebook OAuth
FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-app-secret"
NEXT_PUBLIC_FACEBOOK_APP_ID="your-facebook-app-id"

# ========================================
# EMAIL & NOTIFICATIONS
# ========================================
# Configuration for sending emails and managing support requests
SUPPORT_EMAIL="support@example.com"
SUPPORT_NAME="UnifyFocus Support"
ADMIN_EMAIL="admin@example.com"

# SMTP Configuration for outgoing emails
# Leave empty to disable email sending (messages logged to console/file)
SMTP_HOST="smtp.mailprovider.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="smtp-user"
SMTP_PASS="smtp-password"
